# ============================================================
# CRMaster .gitignore — temiz sürüm
# (Önceki dosya, bozuk echo komutlarının yüzlerce kez eklediği
#  tekrar satırlarıyla dolmuştu; sadeleştirildi.)
# ============================================================

# --- Çalışma zamanı dosyaları (sunucuda üretilir, Git'e girmemeli) ---
backend/sessions.json
backend/user_permissions.json
backend/uploads/
backend/backups/

# --- Ortam değişkenleri ve gizli anahtarlar ---
.env
.env.*
*.env
*.pem
*.key
credentials.json
*token.json*

# --- Python ---
__pycache__/
*.pyc
venv/
.venv/

# --- Node / React ---
node_modules/
frontend/build/
/build
dist/
.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Geliştirme sürecinden kalan klasörler ---
backups/
memory/
test_reports/
.ipynb_checkpoints/

# --- Arşiv dosyaları ---
*.zip
*.tar.gz
*.tar
*.tgz

# --- İşletim sistemi / editör ---
.DS_Store
Thumbs.db
.vscode/
.idea/
